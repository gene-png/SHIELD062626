# SHIELD by Kentro v2.0 - environment variables (example)
#
# Copy to .env and fill in real values for local development.
# .env is gitignored. NEVER commit real secrets.
# Spec references: Master Spec §4.4 (LLM), §4.5 (auth), §12 (redaction).

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Database (Postgres 16 - locked, Master Spec §2)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://shield:shield@db:5432/shield

# ---------------------------------------------------------------------------
# Redis (Celery queue + ephemeral cache - Master Spec §11)
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Object storage (MinIO in dev; S3 + KMS in prod - Master Spec §11)
# ---------------------------------------------------------------------------
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=shield-artifacts
S3_ACCESS_KEY=shield-minio
S3_SECRET_KEY=shield-minio-secret
S3_KMS_KEY_ID=dev-stub-key

# ---------------------------------------------------------------------------
# Keycloak / OIDC (Master Spec §4.5)
# ---------------------------------------------------------------------------
KEYCLOAK_ISSUER=http://keycloak:8080/realms/shield
KEYCLOAK_AUDIENCE=shield-api
KEYCLOAK_CLIENT_ID=shield-web
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# NextAuth (web)
# Generate NEXTAUTH_SECRET with: openssl rand -hex 32
# ---------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-output-of-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# LLM provider (Master Spec §4.4 - env-configurable, NEVER hardcoded)
# Allowed providers: anthropic, openai, azure_openai, bedrock, gemini, local
# SHIELD_LLM_MODE: fixture (offline test mode) | live (real API calls)
# ---------------------------------------------------------------------------
SHIELD_LLM_PROVIDER=anthropic
SHIELD_LLM_MODEL=claude-opus-4-7
SHIELD_LLM_MODE=fixture
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Feature flags (Master Spec §2 locked decisions - deferred for v1)
# ---------------------------------------------------------------------------
SHIELD_AUTH_REQUIRE_MFA=false
SHIELD_AUTH_REQUIRE_EMAIL_VERIFY=false
SHIELD_EMAIL_DELIVERY_ENABLED=false

# ---------------------------------------------------------------------------
# Redaction (Master Spec §12 - mandatory security boundary, not cosmetic)
# Values: strict | standard | off  (off forbidden outside dev)
# ---------------------------------------------------------------------------
SHIELD_REDACTION_MODE=strict

# ---------------------------------------------------------------------------
# Session security (Master Spec §4.5)
# ---------------------------------------------------------------------------
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1800
SHIELD_ACCOUNT_LOCKOUT_MAX_ATTEMPTS=10
SHIELD_ACCOUNT_LOCKOUT_WINDOW_SECONDS=900
SHIELD_IDLE_TIMEOUT_SECONDS=1800
SHIELD_FORCED_REAUTH_SECONDS=86400

# ---------------------------------------------------------------------------
# Mail (MailHog in dev; SES/Graph in prod)
# ---------------------------------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@shield.local
